# Optional terminal tools that are useful across environments but not bootstrap-required.
if OS.mac?
  # Consider deleting this if Apple clang/CLT remains sufficient for your builds.
  brew "gcc"
  brew "autoconf"
end

brew "ast-grep"
brew "lua"
brew "luarocks"
brew "bat-extras"
brew "btop"
brew "imagemagick"
brew "lynx"
brew "shellcheck"
brew "shfmt"
brew "tree"
brew "yq"
