# Required terminal baseline for all machines; bootstrap installs this file only.
if OS.mac?
  brew "bash"
  brew "coreutils"
  brew "gnu-tar"
  brew "openssl@3"
end

brew "bat"
brew "curl"
brew "eza"
brew "fd"
brew "fzf"
brew "gh"
brew "git"
brew "git-delta"
brew "glow"
brew "jq"
brew "lazygit"
brew "less"
brew "neovim"
brew "ripgrep"
brew "ruff"
brew "starship"
brew "tmux"
brew "urlview"
brew "wget"
