{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": ["?.lua", "?/init.lua"],
    "pathStrict": true
  },
  "diagnostics": {
    "globals": ["vim", "LazyVim"],
    "unusedLocalExclude": ["_*"]
  },
  "workspace": {
    "library": ["$VIMRUNTIME", "${3rd}/busted/library"],
    "ignoreDir": [".tests", ".test-deps"],
    "checkThirdParty": false
  }
}
