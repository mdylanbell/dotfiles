#!/usr/bin/env bash
set -euo pipefail

REPO_SLUG="mdylanbell/dotfiles"
# Args override env defaults.
DOTDIR="${DOTFILES_ROOT:-${HOME}/.dotfiles}"
DFM=""
SKIP_GIT="${DOTFILES_SKIP_GIT:-}"
REPO_BRANCH="${DOTFILES_BRANCH:-main}"
ZSH_DEFAULT_ANSWER=""
ENTER_SHELL=0
SHELL_CHANGED=0

log() { printf "\033[1;32m==>\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m!!\033[0m %s\n" "$*"; }
die() {
  printf "\033[1;31mXX\033[0m %s\n" "$*\n"
  exit 1
}
is_cmd() { command -v "$1" >/dev/null 2>&1; }
current_shell_name() {
  local current_shell
  current_shell="$(ps -p "$$" -o comm= 2>/dev/null || true)"
  printf '%s\n' "${current_shell##*/}"
}

print_help() {
  cat <<EOF
Usage: bootstrap_env [options]

Bootstrap this dotfiles environment on a fresh machine or test harness.

Options:
  --help                 Show this help and exit
  --dotfiles-root=PATH   Dotfiles checkout to bootstrap
  --branch=NAME          Dotfiles branch to clone/update (default: main)
  --skip-git             Skip git clone/fetch/pull operations
  --zsh-default=y|n      Pre-answer the default-shell prompt
  --enter-shell          Enter zsh after bootstrap completes
EOF
}

parse_args() {
  while (($#)); do
    case "$1" in
      --help)
        print_help
        exit 0
        ;;
      --dotfiles-root=*)
        DOTDIR="${1#*=}"
        ;;
      --branch=*)
        REPO_BRANCH="${1#*=}"
        [[ -n "$REPO_BRANCH" ]] || die "invalid value for --branch: empty"
        ;;
      --skip-git)
        SKIP_GIT=1
        ;;
      --zsh-default=*)
        ZSH_DEFAULT_ANSWER="${1#*=}"
        case "$ZSH_DEFAULT_ANSWER" in
          y | Y | n | N) ;;
          *) die "invalid value for --zsh-default: $ZSH_DEFAULT_ANSWER (expected y or n)" ;;
        esac
        ;;
      --enter-shell)
        ENTER_SHELL=1
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
    shift
  done

  DFM="${DOTDIR}/.local/bin/dfm"
}

load_bootstrap_env() {
  if [[ -f "$DOTDIR/.zshenv" ]]; then
    # shellcheck source=~/.dotfiles/.zshenv disable=SC1090
    source "$DOTDIR/.zshenv"
  fi

  local xdg_conf="$DOTDIR/.config/zsh/conf.d/50-xdg.zsh"
  if [[ -f "$xdg_conf" ]]; then
    # shellcheck disable=SC1090
    source "$xdg_conf"
  fi

  local zsh_env="$DOTDIR/.config/zsh/env.zsh"
  if [[ -f "$zsh_env" ]]; then
    # shellcheck disable=SC1090
    source "$zsh_env"
  fi
}

choose_remote() {
  if ssh -o BatchMode=yes -o ConnectTimeout=2 -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
    echo "git@github.com:${REPO_SLUG}.git"
  else
    echo "https://github.com/${REPO_SLUG}.git"
  fi
}

ensure_linux_deps() {
  warn "Installing system packages (Linux only)…"
  case "$(uname -s)" in
    Darwin) die "Please run 'xcode-select --install' once, then re-run." ;;
    Linux)
      if is_cmd apt-get; then
        sudo apt-get update && sudo apt-get install -y \
          git \
          curl \
          ca-certificates \
          zsh \
          build-essential \
          libc6-dev \
          libncurses-dev \
          file
      elif is_cmd dnf; then
        sudo dnf install -y git curl ca-certificates
      elif is_cmd pacman; then
        sudo pacman -Sy --noconfirm git curl ca-certificates
      else die "No supported package manager for git/curl. Install manually."; fi
      ;;
    *) die "Unknown OS." ;;
  esac
}

ensure_brew() {
  if is_cmd brew; then
    log "Homebrew: $(brew --prefix)"
    return
  fi
  log "Installing Homebrew/Linuxbrew…"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    if [[ -x /opt/homebrew/bin/brew ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    else eval "$(/usr/local/bin/brew shellenv)"; fi
  else
    if [[ -x "$HOME/.linuxbrew/bin/brew" ]]; then
      eval "$("$HOME/.linuxbrew/bin/brew" shellenv)"
    else eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"; fi
  fi
}

ensure_mise() {
  export PATH="$HOME/.local/bin:$PATH"

  if is_cmd mise; then
    log "mise: $(mise --version)"
    return
  fi

  log "Installing mise…"
  curl https://mise.run | sh
  export PATH="$HOME/.local/bin:$PATH"
  is_cmd mise || die "mise install completed but mise is still not on PATH"
}

install_bootstrap_prereqs() {
  # These prereqs must exist before `mise run bootstrap`, not inside bootstrap
  # tasks, because mise currently resolves npm-backed tool metadata during
  # `mise run` startup before task execution. Without node/npm in place, that
  # produces a large amount of warning spam. We also want gpg available before
  # the main `mise install` for verification.
  log "bootstrap prereqs"
  brew install gpg
  mise install node
}

sync_dotfiles() {
  if [[ -n "${SKIP_GIT}" ]]; then
    echo "dotfiles bootstrap: skipping git fetch/clone of dotfiles repository"
    return
  fi

  local remote
  remote="$(choose_remote)"
  if [[ -d "$DOTDIR/.git" ]]; then
    log "Updating dotfiles in $DOTDIR"
    git -C "$DOTDIR" fetch --all --tags
    git -C "$DOTDIR" checkout "$REPO_BRANCH"
    git -C "$DOTDIR" pull --ff-only origin "$REPO_BRANCH"
  else
    log "Cloning dotfiles into $DOTDIR"
    git clone --branch "$REPO_BRANCH" "$remote" "$DOTDIR"
  fi
  log "Init submodules"
  git -C "$DOTDIR" submodule update --init --recursive
}

run_dfm_install() {
  [[ -x "$DFM" ]] || die "dfm not found at $DFM"
  log "dfm install"
  "$DFM" install
}

trust_mise_config() {
  log "mise trust"
  mise trust -a -y -C "$DOTDIR" || true
}

run_bootstrap() {
  log "mise run bootstrap"
  MISE_TASK_RUN_AUTO_INSTALL=0 MISE_AUTO_INSTALL=0 mise run bootstrap
}

maybe_set_default_shell() {
  local current_shell
  current_shell="$(current_shell_name)"
  if [[ "$current_shell" == "zsh" ]]; then
    return
  fi

  local zsh_path
  zsh_path="$(command -v zsh || true)"
  [[ -n "$zsh_path" ]] || die "zsh not found on PATH"

  local target_user
  target_user="${USER-$(id -un)}"

  local shell_switch_reply
  echo "zsh is not the current shell (detected: ${current_shell:-unknown})."
  printf "Switch default shell to zsh? [Y/n] "
  if [[ -n "$ZSH_DEFAULT_ANSWER" ]]; then
    shell_switch_reply="$ZSH_DEFAULT_ANSWER"
    printf "%s (auto-answered via --zsh-default)\n" "$shell_switch_reply"
  else
    read -r shell_switch_reply
  fi

  case "${shell_switch_reply:-Y}" in
    Y | y | YES | Yes | yes)
      sudo chsh -s "$zsh_path" "$target_user"
      SHELL_CHANGED=1
      ;;
    *) ;;
  esac
}

maybe_enter_shell() {
  if (( ! ENTER_SHELL )); then
    return
  fi

  local current_shell
  current_shell="$(current_shell_name)"
  if [[ "$current_shell" == "zsh" ]]; then
    return
  fi

  local zsh_path
  zsh_path="$(command -v zsh || true)"
  [[ -n "$zsh_path" ]] || die "zsh not found on PATH"
  exec "$zsh_path" -l
}

print_completion_message() {
  if (( SHELL_CHANGED )); then
    log "Default shell changed to zsh."
    printf "Close this session and start a new terminal/session to pick it up.\n"
    printf "If you want to switch right now instead, run: zsh -l\n"
  else
    log "Done. Open a new shell or run: zsh -l"
  fi
}

main() {
  # Phase 1: Resolve CLI/env inputs and load bootstrap-time environment.
  parse_args "$@"
  load_bootstrap_env

  # Phase 2: Ensure machine-level prerequisites exist.
  ensure_linux_deps
  ensure_brew

  # Phase 3: Ensure the dotfiles checkout is present and linked.
  sync_dotfiles
  run_dfm_install

  # Phase 4: Prepare mise/bootstrap prerequisites and run bootstrap.
  ensure_mise
  trust_mise_config
  install_bootstrap_prereqs
  run_bootstrap

  # Phase 5: Optional shell follow-up and completion messaging.
  maybe_set_default_shell
  print_completion_message
  maybe_enter_shell
}

main "$@"
